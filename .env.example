# =============================================================================
# Finance Dashboard — environment template
# =============================================================================
# Copy this file to ".env" in the project root and fill in real values.
#
#   copy .env.example .env   (Windows CMD)
#   Copy-Item .env.example .env   (PowerShell)
#
# The file ".env" is gitignored. Never commit secrets.
#
# Precedence: operating-system environment variables win over this file.
# Spring reads these via application.yml placeholders after DotenvBootstrap runs.
# =============================================================================

# --- PostgreSQL (required) ---
SPRING_DATASOURCE_URL=YOUR_DB_URL
SPRING_DATASOURCE_USERNAME=YOUR_DB_NAME
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# --- JWT signing key (required for non-test runs) ---
# Generate a strong random string, e.g.:
#   PowerShell:  -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})
#   openssl:     openssl rand -base64 48
APP_JWT_SECRET=replace-with-at-least-32-characters-random-secret

# Optional overrides (defaults shown; uncomment to change)
# APP_JWT_EXPIRATION_MS=86400000
# SERVER_PORT=8080
# APP_RATE_LIMIT_REQUESTS_PER_MINUTE=100

# GraphiQL UI — set false in production
SPRING_GRAPHQL_GRAPHIQL_ENABLED=true
